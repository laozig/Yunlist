# Admin password for login
ADMIN_PASSWORD=changeme

# JWT secret (use a long random string)
JWT_SECRET=your-very-secret-key

# File storage path
# Native PM2 deployment: recommended to keep relative path
# Docker deployment: docker-compose.yml will override this to container path
FILES_ROOT=./data/files

# SQLite database path
# Native PM2 deployment: recommended to keep relative path
# Docker deployment: docker-compose.yml will override this to container path
DB_PATH=./data/db/yunlist.db

# Frontend build output path
# Native PM2 deployment: frontend/dist
# Docker deployment: docker-compose.yml will override this to container path
FRONTEND_DIST_PATH=./frontend/dist

# Server port
PORT=3000
