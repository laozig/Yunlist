# Admin password for login
ADMIN_PASSWORD=changeme

# JWT secret (use a long random string)
JWT_SECRET=your-very-secret-key

# Absolute path to the directory you want to serve
FILES_ROOT=/data/yunlist/files

# SQLite database path (recommended for Docker deployment)
DB_PATH=/data/yunlist/db/yunlist.db

# Frontend build output path inside container/runtime
FRONTEND_DIST_PATH=/app/frontend/dist

# Server port
PORT=3000
